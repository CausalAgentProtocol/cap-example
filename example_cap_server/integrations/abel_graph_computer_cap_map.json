  "stage_pipeline_map": {
    "parse": {
      "owner": "cap-example",
      "functions": [
        {
          "module": "example_cap_server.market_pipeline.parser",
          "function": "parse_cap_request",
          "purpose": "Parse CAP envelope and extract focal nodes from params."
        }
      ]
    },
    "graph_operations": {
      "owner": "cap-example",
      "notes": [
        "Toy graph only in this example.",
        "Retrieval is bounded local traversal over in-memory graph."
      ],
      "functions": [
        {
          "module": "example_cap_server.market_pipeline.graph_ops",
          "function": "build_local_graph",
          "async": true,
          "purpose": "Build bounded local graph excerpt around requested nodes."
        }
      ]
    },
    "calculation": {
      "owner": "cap-example",
      "functions": [
        {
          "module": "example_cap_server.market_pipeline.graph_ops",
          "function": "calculate_verb_result",
          "async": true,
          "purpose": "Run verb-specific toy graph calculation."
        }
      ]
    },
    "postprocess": {
      "owner": "cap-example",
      "functions": [
        {
          "module": "example_cap_server.market_pipeline.postprocess",
          "function": "build_postprocess",
          "purpose": "Build node properties and parent/neighbor summaries."
        }
      ]
    },
    "analysis": {
      "owner": "cap-example",
      "functions": [
        {
          "module": "example_cap_server.market_pipeline.analysis",
          "function": "build_analysis",
          "purpose": "Summarize graph/calculation/postprocess statistics."
        }
      ]
    }
  },
